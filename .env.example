# LLM API Keys (choose one or more for fallback)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Observability (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=quiz-agent

# Database
DATABASE_PATH=./data/quiz.db

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=5
MAX_CONTENT_LENGTH=12000

# Quiz Configuration
MIN_QUESTIONS=5
MAX_QUESTIONS=8
ANSWERS_PER_QUESTION=4

# Allowed domains for URL fetching (comma-separated)
ALLOWED_DOMAINS=github.com,raw.githubusercontent.com,gist.github.com
