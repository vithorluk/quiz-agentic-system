# LLM API Keys (choose one or more for fallback)
# Priority order: Anthropic > xAI > Groq > OpenAI
ANTHROPIC_API_KEY=your_anthropic_api_key_here
XAI_API_KEY=your_xai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Observability (optional - enables LangSmith tracing for ALL LLM providers)
# Get your API key from https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_langsmith_api_key_here
# Alternative: LANGSMITH_API_KEY also works
LANGCHAIN_PROJECT=quiz-agent
# Optional: LANGCHAIN_ENDPOINT=https://api.smith.langchain.com (default)

# Database
DATABASE_PATH=./data/quiz.db

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=5
MAX_CONTENT_LENGTH=12000

# Quiz Configuration
MIN_QUESTIONS=5
MAX_QUESTIONS=8
ANSWERS_PER_QUESTION=4

# Allowed domains for URL fetching (comma-separated)
ALLOWED_DOMAINS=github.com,raw.githubusercontent.com,gist.github.com
